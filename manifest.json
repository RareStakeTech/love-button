{
  "manifest_version": 3,
  "name": "ReddID — Tip with RDD",
  "short_name": "ReddID Tip",
  "version": "2.4.0",
  "description": "Send Ɍ ReddCoin tips to creators on Twitter/X, Reddit, YouTube, Twitch, Instagram, TikTok, Bluesky, Mastodon, Rumble, TruthSocial, Odysee, Kick, and GitHub. Powered by ReddID Next.",

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "ReddID Tip Button",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+R",
        "mac":     "Alt+Shift+R"
      },
      "description": "Open ReddID Tip Button"
    }
  },

  "content_scripts": [
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["content/twitter.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "https://www.reddit.com/user/*",
        "https://www.reddit.com/u/*",
        "https://reddit.com/user/*",
        "https://reddit.com/u/*"
      ],
      "js": ["content/reddit.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "https://www.youtube.com/@*",
        "https://www.youtube.com/channel/*",
        "https://www.youtube.com/c/*",
        "https://www.youtube.com/user/*"
      ],
      "js": ["content/youtube.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["https://www.twitch.tv/*"],
      "js": ["content/twitch.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content/instagram.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["https://www.tiktok.com/*"],
      "js": ["content/tiktok.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["https://bsky.app/*"],
      "js": ["lib/reddid-platform-util.js", "content/bluesky.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "https://mastodon.social/*",
        "https://mastodon.online/*",
        "https://fosstodon.org/*",
        "https://infosec.exchange/*",
        "https://mstdn.social/*",
        "https://hachyderm.io/*",
        "https://techhub.social/*",
        "https://mastodon.world/*",
        "https://aus.social/*",
        "https://social.coop/*",
        "https://sigmoid.social/*",
        "https://indieweb.social/*",
        "https://mastodon.gamedev.place/*",
        "https://scholar.social/*",
        "https://universeodon.com/*"
      ],
      "js": ["lib/reddid-platform-util.js", "content/mastodon.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["https://rumble.com/*"],
      "js": ["lib/reddid-platform-util.js", "content/rumble.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["https://truthsocial.com/*"],
      "js": ["lib/reddid-platform-util.js", "content/truthsocial.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["https://odysee.com/*"],
      "js": ["lib/reddid-platform-util.js", "content/odysee.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["https://kick.com/*"],
      "js": ["lib/reddid-platform-util.js", "content/kick.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*",
    "https://www.reddit.com/*",
    "https://reddit.com/*",
    "https://www.youtube.com/*",
    "https://www.twitch.tv/*",
    "https://www.instagram.com/*",
    "https://www.tiktok.com/*",
    "https://bsky.app/*",
    "https://mastodon.social/*",
    "https://mastodon.online/*",
    "https://fosstodon.org/*",
    "https://infosec.exchange/*",
    "https://mstdn.social/*",
    "https://hachyderm.io/*",
    "https://techhub.social/*",
    "https://mastodon.world/*",
    "https://aus.social/*",
    "https://social.coop/*",
    "https://sigmoid.social/*",
    "https://indieweb.social/*",
    "https://mastodon.gamedev.place/*",
    "https://scholar.social/*",
    "https://universeodon.com/*",
    "https://rumble.com/*",
    "https://truthsocial.com/*",
    "https://odysee.com/*",
    "https://kick.com/*"
  ],

  "permissions": [
    "storage",
    "activeTab",
    "contextMenus"
  ],

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["<all_urls>"]
    }
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "reddid-tipbutton@rarestaketech.com",
      "strict_min_version": "109.0"
    }
  }
}
